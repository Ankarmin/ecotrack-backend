DATABASE_TARGET=auto

# Railway/Postgres URL directa.
# En Railway se prioriza DATABASE_URL interno y luego DATABASE_PUBLIC_URL.
DATABASE_URL=
DATABASE_PUBLIC_URL=

# Fallback local para docker/postgres.
PORT=3001
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_DB=ecotrack
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
DATABASE_SSL=false

JWT_SECRET=replace-this-with-a-long-random-secret
JWT_EXPIRES_IN=604800
CORS_ORIGINS=http://localhost:3000,https://ecotrack-frontend-beta.vercel.app,https://*.vercel.app
APP_PUBLIC_URL=http://localhost:${PORT}
