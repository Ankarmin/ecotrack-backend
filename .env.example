DATABASE_URL=postgresql://postgres:password@host:5432/database
# Railway fallback: if DATABASE_URL is not present, the app also supports
# PGHOST, PGPORT, PGDATABASE, PGUSER and PGPASSWORD.
# Additional fallbacks are supported too:
# DATABASE_HOST, DATABASE_PORT, DATABASE_NAME, DATABASE_USER, DATABASE_PASSWORD
# DB_HOST, DB_PORT, DB_NAME, DB_USER, DB_PASSWORD
# POSTGRES_HOST, POSTGRES_PORT, POSTGRES_DB, POSTGRES_USER, POSTGRES_PASSWORD
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=604800
CORS_ORIGINS=http://localhost:3000,https://ecotrack-frontend-beta.vercel.app,https://*.vercel.app
PORT=3001
